# ブランド（デプロイ単位）。axeon | ideal
# Vercel ではプロジェクトごとに設定し、互いのURLを入れないこと
VITE_BRAND=axeon

# 製品説明リンク（任意）。ideal は公式サイト等を指定。未設定なら ideal では非表示、axeon は /lp
# VITE_PRODUCT_INFO_URL=https://example.com

# Managed Trial（Studio /admin/trial と同じ Upstash を共有）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRIAL_DEFAULT_MODEL=gpt-5-nano

# 体験コード取得の共通飛ばし先（Studio /admin/trial）
# ローカル例: http://localhost:3000/admin/trial
# 現行本番（正）: https://ai-demo-studio-lime.vercel.app/admin/trial
# 将来 DNS: https://demo.axeon.jp/admin/trial（未切替）
VITE_TRIAL_PORTAL_URL=https://ai-demo-studio-lime.vercel.app/admin/trial

# 投資回収CTA（roi-simulator の origin のみ。未設定なら CTA 非表示）
# product_flow と同じ localhost:5173 にしないこと（同一オリジンになり ?kit= だけが付く）
# ローカル例: http://localhost:5174 など（roi-simulator の dev ポート）
# 本番例: https://roi-simulator-eta.vercel.app
VITE_ROI_SIMULATOR_URL=https://roi-simulator-eta.vercel.app

# 相談CTA（ideal /contact など）。未設定なら CTA 非表示
# 例: https://www.example.com/contact?intent=gallery&demo=manufacturing
VITE_CONTACT_URL=
