# ConformSystem AI Mode
#
# ローカル: .env.local に記載（npm run dev）
# Vercel: Project Settings → Environment Variables

# サーバー経路（server-proxy /api/ask）および Managed Trial Gateway
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Managed Trial（Studio /admin/trial と同じ Upstash を共有）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRIAL_DEFAULT_MODEL=gpt-5-nano

# お客様向け体験コード取得（Studio /trial）
# ローカル例: http://localhost:3000/trial
# 本番例: https://demo.axeon.jp/trial
# ※ /admin/trial は管理者専用。お客様導線には使わない
VITE_TRIAL_PORTAL_URL=
